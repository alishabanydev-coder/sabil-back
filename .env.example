PORT=5000
# Comma-separated frontend origins. Leave unset in local dev to allow all origins.
# CORS_ORIGINS=https://sabeelkids.com,https://www.sabeelkids.com,http://localhost:3000
MONGO_URI=mongodb://127.0.0.1:27017/kidsContent
ADMIN_USERNAME=admin
ADMIN_PASSWORD=123
ADMIN_JWT_SECRET=replace-with-a-long-random-secret
USER_JWT_SECRET=replace-with-another-long-random-secret
ALTCHA_HMAC_SECRET=replace-with-a-long-random-altcha-secret
